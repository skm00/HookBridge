{
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "hookbridge"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "SecurityProtocol": "Plaintext",
    "ConsumerGroupId": "hookbridge-worker",
    "EnableAutoCommit": false,
    "MessageTimeoutMs": 10000
  },
  "Stripe": {
    "SecretKey": "",
    "WebhookSecret": "",
    "StarterPriceId": "",
    "ProPriceId": "",
    "EnterprisePriceId": "",
    "SuccessUrl": "http://localhost:3000/billing/success",
    "CancelUrl": "http://localhost:3000/billing/cancel"
  },
  "Jwt": {
    "Issuer": "HookBridge",
    "Audience": "HookBridge.Admin",
    "Secret": "dev-only-super-secret-key-change-me-please",
    "ExpiryMinutes": 60
  },
  "Elastic": {
    "ElasticsearchUrl": "http://localhost:9200",
    "Environment": "Development",
    "ServiceName": "hookbridge-api",
    "EnableElasticsearchSink": false
  },
  "ElasticApm": {
    "ServerUrl": "http://localhost:8200",
    "ServiceName": "hookbridge-api",
    "Environment": "Development",
    "Enabled": false
  },
  "RateLimit": {
    "Enabled": true,
    "EventIngestionPermitLimit": 100,
    "EventIngestionWindowSeconds": 60,
    "AdminApiPermitLimit": 300,
    "AdminApiWindowSeconds": 60
  },
  "Security": {
    "AllowPrivateNetworkTargetUrls": true
  },
  "Encryption": {
    "MasterKey": "local-dev-32-byte-minimum-secret-key"
  },
  "Email": {
    "Enabled": false,
    "Provider": "Smtp",
    "SmtpHost": "",
    "SmtpPort": 587,
    "SmtpUsername": "",
    "SmtpPassword": "",
    "FromEmail": "noreply@hookbridge.local",
    "FromName": "HookBridge",
    "UseSsl": true
  },
  "DemoData": {
    "Enabled": true,
    "AdminEmail": "demo@hookbridge.local",
    "AdminPassword": "DemoPassword123!",
    "TenantName": "Demo Company",
    "TenantSlug": "demo-company"
  },
  "DataRetention": {
    "Enabled": true,
    "IncomingEventsDays": 30,
    "DeliveryLogsDays": 30,
    "FailedEventsDays": 90,
    "AuditLogsDays": 90,
    "NotificationsDays": 30
  },
  "FeatureFlags": {
    "Flags": {
      "EnableBilling": true,
      "EnableEmailNotifications": false,
      "EnableAdvancedDashboard": true,
      "EnableAuditLogs": true
    },
    "TenantFeatureOverrides": [
      {
        "TenantId": "tenant-beta",
        "FlagName": "EnableAdvancedDashboard",
        "IsEnabled": false
      }
    ]
  },
  "AIPrompts": {
    "DefaultVersion": "v1.0.0",
    "Prompts": {
      "WebhookFailureAnalysis": "v1.0.0",
      "AiLogSummary": "v1.0.0",
      "PayloadSchemaDetection": "v1.0.0",
      "JsonToDtoSuggestion": "v1.0.0",
      "FluentValidationRuleGeneration": "v1.0.0",
      "WebhookTransformationRecommendation": "v1.0.0",
      "AiSecurityAnalysis": "v1.0.0",
      "NaturalLanguageQuery": "v1.0.0"
    }
  }
}
