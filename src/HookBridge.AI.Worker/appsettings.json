{
  "AI": {
    "Enabled": true,
    "Provider": "Ollama",
    "Model": "llama3",
    "Endpoint": "http://localhost:11434",
    "TimeoutSeconds": 30,
    "MaxRetries": 3,
    "SystemPrompt": "You are HookBridge AI, an assistant for webhook failure analysis and event processing.",
    "EnablePromptLogging": false,
    "EnableFallback": true,
    "LlmRequestTimeoutSeconds": 30,
    "MaxFallbackSummaryLength": 1000,
    "HealthCheckPrompt": "Say HookBridge AI is ready",
    "MaxPromptPayloadLength": 4000,
    "MaskSensitiveValues": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AiKafka": {
    "BootstrapServers": "localhost:9092",
    "SecurityProtocol": "Plaintext",
    "SaslMechanism": "",
    "SaslUsername": "",
    "SaslPassword": "",
    "AiAnalysisTopic": "hookbridge.ai.analysis",
    "PayloadSchemaDetectionTopic": "hookbridge.ai.schema-detection",
    "JsonToDtoSuggestionTopic": "hookbridge.ai.dto-suggestion",
    "ConsumerGroupId": "hookbridge-ai-worker",
    "EnableAutoCommit": false,
    "FluentValidationRuleGenerationTopic": "hookbridge.ai.validation-rule-generation",
    "WebhookTransformationRecommendationTopic": "hookbridge.ai.transformation-recommendation",
    "CustomerEndpointRiskScoreTopic": "hookbridge.ai.endpoint-risk-score",
    "WebhookFailureAnomalyDetectionTopic": "hookbridge.ai.failure-anomalies",
    "AnomaliesTopic": "hookbridge.ai.anomalies",
    "SecurityAnalysisTopic": "hookbridge.ai.security-analysis",
    "DuplicateReplayDetectionTopic": "hookbridge.ai.duplicate-replay-detection",
    "RetryAgentTopic": "hookbridge.ai.retry-agent",
    "SecurityAgentTopic": "hookbridge.ai.security-agent",
    "TransformationAgentTopic": "hookbridge.ai.transformation-agent",
    "ObservabilityAgentTopic": "hookbridge.ai.observability-agent",
    "AutoRemediationTopic": "hookbridge.ai.auto-remediation"
  },
  "AiMongo": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "hookbridge_ai",
    "AiAnalysisResultsCollectionName": "ai_analysis_results",
    "PayloadSchemaDetectionResultsCollectionName": "payload_schema_detection_results",
    "JsonToDtoSuggestionResultsCollectionName": "json_to_dto_suggestion_results",
    "FluentValidationRuleGenerationResultsCollectionName": "fluent_validation_rule_generation_results",
    "WebhookTransformationRecommendationResultsCollectionName": "webhook_transformation_recommendation_results",
    "CustomerEndpointRiskScoreResultsCollectionName": "customer_endpoint_risk_score_results",
    "WebhookFailureAnomalyDetectionResultsCollectionName": "webhook_failure_anomaly_detection_results",
    "AiAnomalyRecordsCollectionName": "ai_anomaly_records",
    "AiSecurityAnalysisResultsCollectionName": "ai_security_analysis_results",
    "WebhookEventFingerprintsCollectionName": "webhook_event_fingerprints",
    "RetryAgentResultsCollectionName": "retry_agent_results",
    "SecurityAgentResultsCollectionName": "security_agent_results",
    "TransformationAgentResultsCollectionName": "transformation_agent_results",
    "ObservabilityAgentResultsCollectionName": "observability_agent_results",
    "AutoRemediationRecommendationResultsCollectionName": "auto_remediation_recommendation_results",
    "AiSafeModeAuditRecordsCollectionName": "ai_safe_mode_audit_records"
  },
  "DuplicateReplayDetection": {
    "Enabled": true,
    "FingerprintTtlHours": 72,
    "ReplayWindowMinutes": 15,
    "FutureTimestampToleranceMinutes": 5,
    "HighFrequencyThreshold": 5,
    "HighFrequencyWindowSeconds": 60,
    "HashAlgorithm": "SHA256"
  },
  "ObservabilityAgent": {
    "Enabled": true,
    "KafkaLagDegradedThreshold": 1000,
    "KafkaLagCriticalThreshold": 10000,
    "MongoLatencyDegradedThresholdMs": 1000,
    "MongoLatencyUnhealthyThresholdMs": 5000,
    "FailureRateDegradedThresholdPercent": 10,
    "FailureRateUnhealthyThresholdPercent": 30,
    "ErrorLogCriticalThreshold": 50,
    "SecurityFindingUnhealthyThreshold": 10,
    "RequireApprovalForCriticalStatus": true,
    "EnableAiLogSummary": true
  },
  "AutoRemediationRecommendation": {
    "Enabled": true,
    "AllowAutoApplyLowRisk": false,
    "RequireApprovalForHighRisk": true,
    "RequireApprovalForCriticalRisk": true,
    "RequireApprovalForSecurityActions": true,
    "RequireApprovalForEndpointPause": true,
    "RequireApprovalForDeadLetterActions": true,
    "LowConfidenceThreshold": 0.6,
    "KafkaLagThreshold": 1000,
    "MongoLatencyThresholdMs": 1000
  },
  "AiSafeMode": {
    "Enabled": true,
    "Environment": "production",
    "BlockProductionActions": true,
    "RequireApprovalForAllProductionActions": true,
    "AllowReadOnlyActions": true,
    "AllowLowRiskActionsInNonProduction": false,
    "AllowAutoApplyInDevelopment": false,
    "LogBlockedActions": true,
    "AuditBlockedActions": true
  }
}
